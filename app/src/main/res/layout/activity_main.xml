<?xml version="1.0" encoding="utf-8"?>
<!-- activity_main.xml — layout for the Main Activity -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="?android:attr/windowBackground">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/main_title"
        android:textSize="24sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:layout_gravity="center"
        android:layout_marginBottom="24dp"
        android:textColor="?android:attr/textColorPrimary"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/input_label"
        android:textSize="16sp"
        android:fontFamily="monospace"
        android:layout_marginBottom="8dp"
        android:textColor="?android:attr/textColorSecondary"/>

    <EditText
        android:id="@+id/editTextInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/input_hint"
        android:inputType="text"
        android:fontFamily="monospace"
        android:layout_marginBottom="12dp"
        android:textColor="?android:attr/textColorPrimary"/>

    <Button
        android:id="@+id/buttonConvert"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/convert_button"
        android:fontFamily="monospace"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/output_label"
        android:textSize="16sp"
        android:fontFamily="monospace"
        android:layout_marginBottom="8dp"
        android:textColor="?android:attr/textColorSecondary"/>

    <TextView
        android:id="@+id/textViewMorseOutput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="60dp"
        android:padding="12dp"
        android:background="#1A808080"
        android:textSize="18sp"
        android:letterSpacing="0.1"
        android:fontFamily="monospace"
        android:layout_marginBottom="24dp"
        android:hint="@string/morse_hint"
        android:textColor="?android:attr/textColorPrimary"/>

    <Button
        android:id="@+id/buttonSendToOutput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/play_output_button"
        android:fontFamily="monospace"
        android:layout_marginBottom="8dp"/>

    <Button
        android:id="@+id/buttonSettings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/settings_button"
        android:fontFamily="monospace"
        android:layout_marginBottom="8dp"/>

    <Button
        android:id="@+id/buttonHelp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/help_button"
        android:fontFamily="monospace"/>

</LinearLayout>