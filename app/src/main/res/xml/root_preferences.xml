<PreferenceScreen xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory app:title="Appearance">

        <SwitchPreferenceCompat
            app:key="dark_mode"
            app:title="Dark Mode"
            app:summary="Switch to dark theme"
            app:defaultValue="false" />

    </PreferenceCategory>

    <PreferenceCategory app:title="Playback">

        <SwitchPreferenceCompat
            app:key="enable_sound"
            app:title="Enable Sound"
            app:summary="Play sound during Morse playback"
            app:defaultValue="true" />

        <ListPreference
            app:defaultValue="classic"
            app:entries="@array/beep_entries"
            app:entryValues="@array/beep_values"
            app:key="beep_sound"
            app:title="Beep Sound"
            app:dependency="enable_sound"
            app:useSimpleSummaryProvider="true" />

        <SwitchPreferenceCompat
            app:key="enable_vibration"
            app:title="Enable Vibration"
            app:summary="Vibrate phone during playback"
            app:defaultValue="true" />

    </PreferenceCategory>

</PreferenceScreen>